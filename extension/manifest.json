{
    "name": "productivity-tracker",
    "version": "0.0.1",
    "manifest_version": 3,
    "description": "Extension to track how productive you have been",
    "permissions": ["tabs", "alarms", "storage", "windows", "webNavigation", "notifications"],
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": ["http://localhost:8000/*"],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Activity Tracker"
    }
}